---
import Page from '../../layouts/Page.astro';
import PostCard from '../../components/PostCard.astro';

const posts = [
  {
    title: '5 señales de alerta del cáncer que no debes ignorar',
    excerpt: 'Conoce los síntomas tempranos más comunes que podrían indicar la presencia de cáncer y cuándo es importante acudir al médico de forma urgente.',
    date: '15 Mar 2026',
    tag: 'Prevención',
    slug: 'senales-alerta-cancer',
    image: 'https://images.unsplash.com/photo-1559757175-5700dde675bc?w=600&q=80',
  },
  {
    title: 'La importancia del chequeo oncológico anual',
    excerpt: 'Un chequeo preventivo anual puede detectar el cáncer en etapas tempranas, aumentando significativamente las posibilidades de curación completa.',
    date: '10 Mar 2026',
    tag: 'Salud',
    slug: 'chequeo-oncologico-anual',
    image: 'https://images.unsplash.com/photo-1579684385127-1ef15d508118?w=600&q=80',
  },
  {
    title: '¿Cómo elegir el mejor seguro oncológico?',
    excerpt: 'Guía completa para comparar seguros contra el cáncer: qué buscar, qué preguntar y cómo tomar la mejor decisión para ti y tu familia.',
    date: '5 Mar 2026',
    tag: 'Seguros',
    slug: 'como-elegir-seguro-oncologico',
    image: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&q=80',
  },
  {
    title: 'Alimentación y prevención del cáncer: lo que dice la ciencia',
    excerpt: 'Descubre qué alimentos pueden ayudar a reducir el riesgo de cáncer según las investigaciones científicas más recientes.',
    date: '28 Feb 2026',
    tag: 'Nutrición',
    slug: 'alimentacion-prevencion-cancer',
    image: 'https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=600&q=80',
  },
  {
    title: 'Cáncer de mama: detección temprana salva vidas',
    excerpt: 'Todo lo que necesitas saber sobre la detección temprana del cáncer de mama: autoexamen, mamografía y factores de riesgo.',
    date: '20 Feb 2026',
    tag: 'Prevención',
    slug: 'cancer-mama-deteccion-temprana',
    image: 'https://images.unsplash.com/photo-1631549916768-4119b2e5f926?w=600&q=80',
  },
  {
    title: 'El impacto emocional del cáncer: cómo afrontarlo en familia',
    excerpt: 'Estrategias psicológicas y recursos de apoyo para pacientes y familias que enfrentan un diagnóstico de cáncer.',
    date: '15 Feb 2026',
    tag: 'Bienestar',
    slug: 'impacto-emocional-cancer',
    image: 'https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=600&q=80',
  },
];
---

<Page title="Blog" description="Artículos sobre prevención del cáncer, salud oncológica, nutrición y bienestar. Información confiable para cuidar tu salud.">
  <section class="blog-hero">
    <div class="container">
      <p class="section-label">📝 Blog</p>
      <h1 class="blog-title">Prevención, salud y bienestar</h1>
      <p class="blog-subtitle">
        Información confiable sobre prevención del cáncer, hábitos saludables y
        todo lo que necesitas saber para cuidar tu salud y la de tu familia.
      </p>
    </div>
  </section>

  <section class="blog-list section">
    <div class="container">
      <div class="blog-grid">
        {posts.map(post => (
          <PostCard {...post} basePath="/blog" />
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .blog-hero {
    padding: 8rem 0 3rem;
    background: linear-gradient(180deg, var(--color-light), var(--color-white));
    text-align: center;
  }
  .blog-title {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-primary-dark);
    margin-bottom: 1rem;
  }
  .blog-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-light);
    max-width: 550px;
    margin: 0 auto;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  @media (max-width: 1024px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .blog-grid { grid-template-columns: 1fr; } }
</style>
