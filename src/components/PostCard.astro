---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  tag: string;
  slug: string;
  image: string;
  basePath: string;
}

const { title, excerpt, date, tag, slug, image, basePath } = Astro.props;
---

<article class="post-card">
  <a href={`${basePath}/${slug}`} class="post-image">
    <img src={image} alt={title} loading="lazy" />
    <span class="post-tag tag">{tag}</span>
  </a>
  <div class="post-body">
    <time class="post-date">{date}</time>
    <h3 class="post-title">
      <a href={`${basePath}/${slug}`}>{title}</a>
    </h3>
    <p class="post-excerpt">{excerpt}</p>
    <a href={`${basePath}/${slug}`} class="post-link">Leer más →</a>
  </div>
</article>

<style>
  .post-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-gray-100);
    transition: all 0.3s;
  }
  .post-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }
  .post-image {
    display: block;
    position: relative;
    overflow: hidden;
    aspect-ratio: 16/9;
  }
  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .post-card:hover .post-image img {
    transform: scale(1.05);
  }
  .post-tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
  }
  .post-body {
    padding: 1.5rem;
  }
  .post-date {
    font-size: 0.78rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .post-title {
    font-size: 1.1rem;
    color: var(--color-primary-dark);
    margin: 0.5rem 0;
    line-height: 1.4;
  }
  .post-title a:hover { color: var(--color-accent); }
  .post-excerpt {
    font-size: 0.88rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: color 0.2s;
  }
  .post-link:hover { color: var(--color-primary); }
</style>
