---
---

<section class="contact section" id="contacto">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <p class="section-label">📩 Contacto</p>
        <h2 class="section-title">¿Tienes preguntas? Escríbenos</h2>
        <p class="contact-desc">
          Nuestros asesores especializados te ayudarán a elegir el plan
          perfecto para ti y tu familia. Respuesta en menos de 24 horas.
        </p>
        <div class="info-cards">
          <div class="info-card">
            <span class="info-icon">📞</span>
            <div>
              <p class="info-title">Llámanos</p>
              <p class="info-value">(01) 700-5000</p>
              <p class="info-extra">Lun - Vie: 8am - 8pm</p>
            </div>
          </div>
          <div class="info-card">
            <span class="info-icon">💬</span>
            <div>
              <p class="info-title">WhatsApp</p>
              <p class="info-value">+51 987 654 321</p>
              <p class="info-extra">Respuesta inmediata</p>
            </div>
          </div>
          <div class="info-card">
            <span class="info-icon">✉</span>
            <div>
              <p class="info-title">Email</p>
              <p class="info-value">info@vidasegura.pe</p>
              <p class="info-extra">Respuesta en 24h</p>
            </div>
          </div>
        </div>
      </div>

      <form class="contact-form">
        <h3 class="form-title">Solicita información</h3>
        <div class="form-row">
          <div class="form-group">
            <label>Nombre</label>
            <input type="text" placeholder="Tu nombre completo" required />
          </div>
          <div class="form-group">
            <label>Teléfono</label>
            <input type="tel" placeholder="+51 999 999 999" required />
          </div>
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" placeholder="tu@email.com" required />
        </div>
        <div class="form-group">
          <label>Plan de interés</label>
          <select required>
            <option value="" disabled selected>Selecciona un plan</option>
            <option>Plan Esencial - S/ 49/mes</option>
            <option>Plan Protección Total - S/ 89/mes</option>
            <option>Plan Familiar Premium - S/ 149/mes</option>
            <option>No estoy seguro, necesito asesoría</option>
          </select>
        </div>
        <div class="form-group">
          <label>Mensaje</label>
          <textarea rows="3" placeholder="Cuéntanos en qué podemos ayudarte..."></textarea>
        </div>
        <button type="submit" class="btn btn-accent" style="width:100%;justify-content:center;">Enviar Solicitud</button>
        <p class="form-note">Tus datos están protegidos. No compartimos tu información.</p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact { background: var(--color-white); }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .contact-desc {
    font-size: 0.95rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  .info-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .info-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-gray-50);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-100);
  }
  .info-icon { font-size: 1.5rem; }
  .info-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-accent);
    font-weight: 600;
  }
  .info-value {
    font-weight: 600;
    color: var(--color-primary-dark);
    font-size: 0.95rem;
  }
  .info-extra {
    font-size: 0.78rem;
    color: var(--color-text-light);
  }
  .contact-form {
    background: var(--color-gray-50);
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-gray-200);
  }
  .form-title {
    font-size: 1.2rem;
    color: var(--color-primary-dark);
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-group {
    margin-bottom: 1rem;
  }
  .form-group label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-gray-700);
    margin-bottom: 0.4rem;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-text);
    background: var(--color-white);
    outline: none;
    transition: border-color 0.2s;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(6,182,212,0.1);
  }
  .form-group textarea { resize: vertical; }
  .form-note {
    text-align: center;
    font-size: 0.78rem;
    color: var(--color-gray-400);
    margin-top: 0.75rem;
  }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
