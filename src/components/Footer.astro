---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span>🛡</span>
          <div>
            <span class="logo-name">VidaSegura</span>
            <span class="logo-tag">Seguro Oncológico</span>
          </div>
        </a>
        <p class="footer-desc">
          Protección integral contra el cáncer para ti y tu familia. Coberturas diseñadas
          para brindarte tranquilidad en los momentos más importantes.
        </p>
        <div class="footer-sbs">
          <span>Regulado por la SBS</span>
        </div>
      </div>

      <div>
        <h4 class="footer-heading">Navegación</h4>
        <ul class="footer-links">
          <li><a href="/">Inicio</a></li>
          <li><a href="/planes">Planes</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/noticias">Noticias</a></li>
        </ul>
      </div>

      <div>
        <h4 class="footer-heading">Planes</h4>
        <ul class="footer-links">
          <li><a href="/planes">Plan Esencial</a></li>
          <li><a href="/planes">Plan Protección Total</a></li>
          <li><a href="/planes">Plan Familiar Premium</a></li>
          <li><a href="/planes">Comparar Planes</a></li>
        </ul>
      </div>

      <div>
        <h4 class="footer-heading">Contacto</h4>
        <ul class="footer-links contact-info">
          <li>📞 (01) 700-5000</li>
          <li>📱 +51 987 654 321</li>
          <li>✉ info@vidasegura.pe</li>
          <li>📍 Av. Rivera Navarrete 501, San Isidro, Lima</li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} VidaSegura. Todos los derechos reservados.</p>
      <div class="footer-legal">
        <a href="#">Términos y Condiciones</a>
        <a href="#">Política de Privacidad</a>
        <a href="#">Libro de Reclamaciones</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-gray-900);
    color: var(--color-gray-400);
    padding: 4rem 0 0;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.3fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-gray-800);
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }
  .logo-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-white);
    display: block;
    line-height: 1.2;
  }
  .logo-tag {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-accent);
    font-weight: 600;
  }
  .footer-desc {
    font-size: 0.88rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .footer-sbs {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--color-accent);
    border: 1px solid var(--color-gray-700);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-sm);
  }
  .footer-heading {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 1.25rem;
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-links a, .contact-info li {
    font-size: 0.88rem;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--color-accent-light); }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    font-size: 0.8rem;
  }
  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }
  .footer-legal a {
    transition: color 0.2s;
  }
  .footer-legal a:hover { color: var(--color-accent-light); }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
    .footer-legal { flex-wrap: wrap; justify-content: center; gap: 1rem; }
  }
</style>
