---
const plans = [
  {
    name: 'Esencial',
    price: '49',
    coverage: '500,000',
    popular: false,
    features: [
      'Cobertura hasta S/ 500,000',
      'Quimioterapia y radioterapia',
      'Cirugías oncológicas',
      'Exámenes de diagnóstico',
      'Red de 80+ clínicas',
    ],
    missing: ['Inmunoterapia', 'Segunda opinión internacional', 'Cobertura en el extranjero'],
  },
  {
    name: 'Protección Total',
    price: '89',
    coverage: '1,500,000',
    popular: true,
    features: [
      'Cobertura hasta S/ 1,500,000',
      'Quimioterapia y radioterapia',
      'Cirugías oncológicas',
      'Medicamentos especializados',
      'Segunda opinión médica',
      'Apoyo psicológico',
      'Red de 120+ clínicas',
    ],
    missing: ['Cobertura en el extranjero'],
  },
  {
    name: 'Familiar Premium',
    price: '149',
    coverage: '3,000,000',
    popular: false,
    features: [
      'Cobertura hasta S/ 3,000,000',
      'Incluye cónyuge e hijos',
      'Todos los tratamientos',
      'Inmunoterapia incluida',
      'Segunda opinión internacional',
      'Cobertura en el extranjero',
      'Cuidados paliativos',
      'Nutricionista oncológico',
    ],
    missing: [],
  },
];
---

<section class="plans section" id="planes">
  <div class="container">
    <div class="section-header center">
      <p class="section-label">💰 Planes</p>
      <h2 class="section-title">Elige tu plan de protección</h2>
      <p class="section-subtitle">Planes flexibles diseñados para cada necesidad. Todos sin periodos de carencia.</p>
    </div>
    <div class="plans-grid">
      {plans.map(plan => (
        <div class:list={['plan-card', { popular: plan.popular }]}>
          {plan.popular && <div class="popular-badge">Más Elegido</div>}
          <div class="plan-header">
            <h3 class="plan-name">{plan.name}</h3>
            <p class="plan-coverage">Cobertura hasta S/ {plan.coverage}</p>
          </div>
          <div class="plan-price">
            <span class="price-currency">S/</span>
            <span class="price-amount">{plan.price}</span>
            <span class="price-period">/mes</span>
          </div>
          <ul class="plan-features">
            {plan.features.map(f => (
              <li class="feature-yes">✓ {f}</li>
            ))}
            {plan.missing.map(m => (
              <li class="feature-no">✗ {m}</li>
            ))}
          </ul>
          <a href="/planes" class:list={['btn', plan.popular ? 'btn-accent' : 'btn-outline']} style="width:100%;justify-content:center;">
            Cotizar Plan
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: start;
  }
  .plan-card {
    background: var(--color-white);
    border: 2px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    position: relative;
    transition: all 0.3s;
  }
  .plan-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
  }
  .plan-card.popular {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-xl);
    transform: scale(1.03);
  }
  .plan-card.popular:hover { transform: scale(1.05) translateY(-4px); }
  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: var(--color-white);
    padding: 0.3rem 1.2rem;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
  }
  .plan-header { margin-bottom: 1.5rem; }
  .plan-name {
    font-size: 1.3rem;
    color: var(--color-primary-dark);
    margin-bottom: 0.25rem;
  }
  .plan-coverage {
    font-size: 0.82rem;
    color: var(--color-text-light);
  }
  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-gray-200);
  }
  .price-currency {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-primary-dark);
  }
  .price-amount {
    font-family: var(--font-heading);
    font-size: 3.2rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    line-height: 1;
  }
  .price-period {
    font-size: 0.9rem;
    color: var(--color-gray-500);
  }
  .plan-features {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }
  .feature-yes {
    font-size: 0.88rem;
    color: var(--color-gray-700);
  }
  .feature-no {
    font-size: 0.88rem;
    color: var(--color-gray-400);
    text-decoration: line-through;
  }

  @media (max-width: 768px) {
    .plans-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
    .plan-card.popular { transform: none; }
    .plan-card.popular:hover { transform: translateY(-4px); }
  }
</style>
