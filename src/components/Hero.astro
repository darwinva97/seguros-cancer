---
---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge">🎗 Mes de la Prevención del Cáncer</div>
      <h1 class="hero-title">
        Protege tu vida y la de tu familia contra el
        <span class="highlight">cáncer</span>
      </h1>
      <p class="hero-text">
        Cobertura oncológica integral desde S/ 49 al mes. Accede a los mejores centros
        especializados del Perú con atención inmediata y sin periodos de carencia.
      </p>
      <div class="hero-actions">
        <a href="/planes" class="btn btn-accent">Ver Planes y Precios</a>
        <a href="#como-funciona" class="btn btn-outline">¿Cómo funciona?</a>
      </div>
      <div class="hero-trust">
        <div class="trust-item">
          <span class="trust-icon">✓</span>
          <span>Sin periodos de carencia</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">✓</span>
          <span>Clínicas de primer nivel</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">✓</span>
          <span>Cobertura desde el día 1</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card">
        <div class="card-header">
          <span class="card-icon">🛡</span>
          <div>
            <p class="card-label">Plan más elegido</p>
            <h3 class="card-plan">Protección Total</h3>
          </div>
        </div>
        <div class="card-price">
          <span class="price-from">desde</span>
          <span class="price-amount">S/ 89</span>
          <span class="price-period">/mes</span>
        </div>
        <ul class="card-features">
          <li>✓ Cobertura hasta S/ 1,500,000</li>
          <li>✓ Quimioterapia y radioterapia</li>
          <li>✓ Cirugías oncológicas</li>
          <li>✓ Medicamentos especializados</li>
          <li>✓ Segunda opinión médica</li>
          <li>✓ Asistencia psicológica</li>
        </ul>
        <a href="/planes" class="btn btn-primary" style="width:100%;justify-content:center;">Cotizar Este Plan</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 8rem 0 5rem;
    overflow: hidden;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 70% 20%, rgba(6,182,212,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 80%, rgba(139,92,246,0.06) 0%, transparent 50%),
      linear-gradient(180deg, var(--color-light) 0%, var(--color-white) 100%);
  }
  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, rgba(139,92,246,0.1), rgba(6,182,212,0.1));
    color: var(--color-hope);
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-full);
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(139,92,246,0.15);
  }
  .hero-title {
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    color: var(--color-primary-dark);
    margin-bottom: 1.25rem;
    line-height: 1.15;
  }
  .highlight {
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-text {
    font-size: 1.1rem;
    color: var(--color-text-light);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.8;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }
  .hero-trust {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-gray-600);
  }
  .trust-icon {
    color: var(--color-success);
    font-weight: 700;
  }
  .hero-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--color-gray-100);
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .card-icon { font-size: 2rem; }
  .card-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-accent);
    font-weight: 600;
  }
  .card-plan {
    font-size: 1.2rem;
    color: var(--color-primary-dark);
  }
  .card-price {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-gray-200);
  }
  .price-from {
    font-size: 0.85rem;
    color: var(--color-gray-500);
  }
  .price-amount {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    font-weight: 800;
    color: var(--color-primary-dark);
  }
  .price-period {
    font-size: 0.9rem;
    color: var(--color-gray-500);
  }
  .card-features {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-bottom: 2rem;
  }
  .card-features li {
    font-size: 0.9rem;
    color: var(--color-gray-600);
  }

  @media (max-width: 768px) {
    .hero { padding: 6rem 0 3rem; min-height: auto; }
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-trust { flex-direction: column; gap: 0.5rem; }
  }
</style>
